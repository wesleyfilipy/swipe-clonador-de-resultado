# URL do painel: https://SEU_REF.supabase.co (sem isso o app tenta 127.0.0.1:54321 e dá ERR_CONNECTION_REFUSED)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Opcional no servidor (ex.: Vercel): mesma chave anon para /api/supabase-public se o build não embutir NEXT_PUBLIC_*
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Modo construção: 1 = feed ilimitado sem assinatura Stripe (banner "Assinar" some). Use na Vercel enquanto não cobra.
FREE_FEED_UNLIMITED=1

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

OPENAI_API_KEY=

META_SYSTEM_USER_TOKEN=
META_AD_ACCOUNT_ID=

CRON_SECRET=

# Mineração diária Ad Library (cron /api/cron/mine-ad-library)
META_AD_LIBRARY_ACCESS_TOKEN=
META_AD_LIBRARY_MAX_ADS=100
META_AD_LIBRARY_PAGES_PER_KEYWORD=4
META_AD_LIBRARY_KEYWORD_COUNT=8

# Sincronização em background (ex.: waitUntil no /api/ads): 0 desliga. Cron Vercel ignora.
AUTO_AD_LIBRARY_SYNC=1
AUTO_AD_LIBRARY_COOLDOWN_MIN=45
AUTO_AD_LIBRARY_FAIL_COOLDOWN_MIN=12

# Bot (pasta /bot) — mineração Ad Library
SUPABASE_URL=
BOT_HEADFUL=0
BOT_MAX_ADS=400
BOT_MAX_PER_KEYWORD=120
BOT_SCROLL_ROUNDS=35
BOT_PROXY_SERVER=
BOT_TRANSCRIBE=0
