# --- Deploy (Vercel): catálogo vazio = public.ads sem linhas ou Graph API/token ---
# 1) Supabase → Table Editor → public.ads tem linhas? Se não, a mineração não inseriu (ou não rodou).
# 2) Vercel → SUPABASE_SERVICE_ROLE_KEY + NEXT_PUBLIC_* (URL + anon). Sem service role o sync em background aborta.
# 3) Vercel → META_AD_LIBRARY_ACCESS_TOKEN (ou META_SYSTEM_USER_TOKEN) + META_APP_SECRET se o app Meta exigir appsecret_proof.
# 4) SQL: complete_install.sql ou migrations (ads, ingest_lock, mine_source) aplicados no mesmo projeto Supabase.

# URL do painel: https://SEU_REF.supabase.co (sem isso o app tenta 127.0.0.1:54321 e dá ERR_CONNECTION_REFUSED)
NEXT_PUBLIC_SUPABASE_URL=
# Chave “pública”: use a legacy `anon` (JWT eyJ...) OU a nova Publishable `sb_publishable_...` (Settings → API Keys).
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Opcional no servidor (ex.: Vercel): mesma chave anon para /api/supabase-public se o build não embutir NEXT_PUBLIC_*
SUPABASE_ANON_KEY=
# Backend: use a legacy `service_role` (JWT) OU a nova Secret `sb_secret_...`. Nunca no browser. Nome da env continua SERVICE_ROLE por compatibilidade.
SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Por padrão o feed já é ilimitado sem Stripe. Defina 0 se quiser limite free + integração Stripe de volta.
FREE_FEED_UNLIMITED=1

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

OPENAI_API_KEY=

META_SYSTEM_USER_TOKEN=
META_AD_ACCOUNT_ID=

CRON_SECRET=
# CRON_SECRET só destrava /api/cron/* e /api/catalog-health. NÃO busca na Meta. Obrigatório para popular ads:
#   META_AD_LIBRARY_ACCESS_TOKEN (+ META_APP_SECRET se o app exigir) e SUPABASE_SERVICE_ROLE_KEY.
# Se o segredo tiver * & # + ou espaço, use header Authorization: Bearer (evita erro de URL).
# Diagnóstico (mesmo segredo do cron). Use o hostname REAL do deploy (Vercel → Deployments → Domínio, ex. projeto.vercel.app):
#   https://projeto.vercel.app/api/catalog-health?secret=<valor de CRON_SECRET>
#   &probe=1 — teste mínimo à Graph API. Se der 404 DEPLOYMENT_NOT_FOUND, a URL está errada ou o app não foi implantado nesse domínio.

# Mineração Ad Library: rode no servidor (cron Vercel + /feed em background). Usuários só leem o catálogo em public.ads.
# Mineração diária Ad Library (cron /api/cron/mine-ad-library)
#
# Mineração via Apify (actor curious_coder/facebook-ads-library-scraper). Com APIFY_TOKEN, a Graph API da Meta **não** é usada na mineração (a não ser que APIFY_ONLY=0 e não haja token Apify).
# Só Apify (recomendado se não quiser token Meta): APIFY_TOKEN + APIFY_ONLY=1 — pode remover META_AD_LIBRARY_ACCESS_TOKEN da Vercel.
APIFY_TOKEN=
# APIFY_ONLY=1
# APIFY_API_TOKEN=
# Padrão: US. Usado no parâmetro country= da URL da Ad Library.
APIFY_AD_LIBRARY_COUNTRY=US
# Teto de anúncios coletados na run (máx. 2000). Vazio = automático: min(2000, max(50, 3 * limite lógico de maxAds do modo)).
# No primeiro preenchimento do /feed: run pequena para não exceder o timeout do waitUntil (Vercel). Aumente com cuidado.
# APIFY_AD_LIBRARY_COUNT=2000
# FEED_QUICK_APIFY_COUNT=64
# FEED_QUICK_WAIT_SECS=95
# Grupo de duplicados = mesmo snapshot/URL de imagem. "Forte" = pelo menos N cópias (padrão 3).
# AD_LIBRARY_DUP_GROUP_MIN=3
# Só grava no catálogo anúncios com >= N duplicatas (lote + contagem da Meta, quando existir). Padrão 50.
# AD_LIBRARY_MIN_DUP_IN_CATALOG=50
# 1 = só anúncios escalados (início há mais de AD_LIBRARY_SCALED_MIN_DAYS dias)
# AD_LIBRARY_CATALOG_REQUIRE_SCALED=0
# 1 = só linhas com vídeo ou thumbnail extraído
# AD_LIBRARY_CATALOG_REQUIRE_MEDIA=0
# Preenchimento rápido do /feed: mínimo de duplicatas (default 1; não aplicar 50 no quick)
# FEED_QUICK_MIN_DUP_IN_CATALOG=1
# Anúncio "escalado" = data de início há mais de N dias (padrão 5).
# AD_LIBRARY_SCALED_MIN_DAYS=5
# Espera a run do Apify terminar (segundos). Crons longos: aumente maxDuration no route e/ou use plano Vercel com timeout maior.
# APIFY_RUN_WAIT_SECS=3600
# APIFY_AD_LIBRARY_SORT_BY=impressions_desc
#
# === Winning Ads Spy (catálogo centralizado, 1x/semana) ===
# SQL: aplica supabase/migration_spy_weekly_ads.sql no Supabase.
# Vercel Hobby: no máx. 1 cron no vercel.json — use GET /api/cron/scheduled (7h UTC) que chama mineração + spy.
# Ainda pode chamar manual: /api/cron/mine-ad-library, /api/cron/spy-weekly?force=1 (mesmo CRON_SECRET).
# SPY: CRON_DISABLE_SPY=1 | legado: CRON_DISABLE_MINE=1
# 1 = bloqueia mineração ao abrir o feed e POST /api/catalog-fill (só o cron alimenta mine_source=spy_weekly + legado).
# SPY_BLOCK_USER_AD_INGEST=0
# SPY_WEEKLY_ENABLED=1
# Mín. horas entre runs bem-sucedidos (padrão 168 = 7 dias). Re-run antes: ?force=1 ou SPY_FORCE_RUN=1
# SPY_MIN_INTERVAL_HOURS=168
# US,BR,CA,UK e keywords (veja lib/spy/config.ts) — overrides:
# SPY_COUNTRIES=US,BR,CA,UK
# SPY_KEYWORDS=fitness,beauty,crypto,make money,ecommerce,supplement
# ~1000–2000 anúncios coletados por país por run
# SPY_ADS_PER_COUNTRY=1500
# Máx. vencedores para os quais buscamos VSL na landing (fetch HTML)
# SPY_VSL_MAX_ENRICH=250
# Token de usuário “curto” na Meta expira em ~1–2 h; para produção use long-lived ou token de sistema (System User) e atualize aqui quando der OAuth 190 / session expired.
META_AD_LIBRARY_ACCESS_TOKEN=
# Obrigatório se no app Meta (Avançado) estiver ligado "Require app secret for server API calls". Erro “Invalid appsecret_proof” (código 100): secret errado ou de outro app — copie de “Básico” do mesmo app do token. Se o app não exige app secret: apague META_APP_SECRET ou use META_AD_LIBRARY_SKIP_APPSECRET_PROOF=1.
META_APP_SECRET=
# META_AD_LIBRARY_SKIP_APPSECRET_PROOF=1
# 502 na mineração: token precisa de acesso à Ad Library API (app em modo desenvolvedor + produto “Facebook Login for Business” / permissões corretas conforme doc Meta), não use token de outro app; confira appsecret_proof se META_APP_SECRET estiver definido.
META_AD_LIBRARY_MAX_ADS=100
META_AD_LIBRARY_PAGES_PER_KEYWORD=4
META_AD_LIBRARY_KEYWORD_COUNT=8
# Máximo de anúncios `ad_library_daily` guardados no Supabase (50–2000). Acima disso, remove os de menor appearance_count e depois views_week.
AD_LIBRARY_CATALOG_CAP=500
# Países ISO separados por vírgula. Ex.: US,GB — a API retorna mais anúncios comuns na UE/UK.
META_AD_LIBRARY_COUNTRIES=US
# ALL | VIDEO | IMAGE — padrão ALL no código; VIDEO sozinho costuma retornar 0 resultados.
META_AD_LIBRARY_MEDIA_TYPE=ALL

# Sincronização em background (ex.: waitUntil no /api/ads): 0 desliga. Cron Vercel ignora.
AUTO_AD_LIBRARY_SYNC=1
AUTO_AD_LIBRARY_COOLDOWN_MIN=45
AUTO_AD_LIBRARY_FAIL_COOLDOWN_MIN=12
# (Legado) Antes usado por trigger em background.
AUTO_AD_LIBRARY_TRIGGER_COOLDOWN_MIN=30

# Cron `/api/cron/mine-ad-library`: funde novos anúncios no catálogo (não apaga tudo) e poda por AD_LIBRARY_CATALOG_CAP.
# Em Hobby o cron Vercel roda no máximo 1x/dia; para atualizar mais vezes, use um scheduler externo chamando a rota com CRON_SECRET.

# /feed com ads vazio: por padrão mineração em background (`waitUntil`, não trava a página). FEED_INSTANT_BLOCKING_FILL=1 força síncrono (até minutos).
# FEED_INSTANT_BLOCKING_FILL=0 desliga qualquer preenchimento automático ao abrir o /feed.
# Demos na base: só com FEED_INSTANT_DEMO_FALLBACK=1 (opt-in). Sem isso, só aparecem anúncios vindos da Meta (Ad Library).
# Apagar demos antigos no Supabase SQL: delete from public.ads where mine_source = 'instant_demo';
# O feed só lista mine_source manual ou ad_library_daily (instant_demo nunca aparece na UI).
# FEED_BLOCKING_MAX_ADS=48 FEED_BLOCKING_PAGES_PER_KEYWORD=2 FEED_BLOCKING_KEYWORD_COUNT=5

# POST /api/catalog-fill: mineração curta (CATALOG_FILL_*). /feed em background (waitUntil): FEED_BLOCKING_* — sem lock compartilhado (o lock `catalog_user_fill` é só para evitar spam no POST).
# CATALOG_FILL_MAX_ADS=22
# CATALOG_FILL_PAGES_PER_KEYWORD=1
# CATALOG_FILL_KEYWORD_COUNT=3
# Lease no início do POST (segundos); ao terminar: sucesso / falha → cooldowns (padrões no código: ~72s / ~40s / ~15s).
# CATALOG_USER_FILL_LEASE_SEC=72
# CATALOG_USER_FILL_COOLDOWN_SEC=40
# CATALOG_USER_FILL_FAIL_COOLDOWN_SEC=15

# Bot (pasta /bot) — Playwright; NÃO roda no deploy Next.js. Só: npm run bot:scrape (ou CI) com env preenchidos.
SUPABASE_URL=
BOT_HEADFUL=0
BOT_MAX_ADS=400
BOT_MAX_PER_KEYWORD=120
BOT_SCROLL_ROUNDS=35
BOT_PROXY_SERVER=
BOT_TRANSCRIBE=0
